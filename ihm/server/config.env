# AI Assistant Configuration
# Set to "true" to enable AI Assistant, "false" for mock mode
USE_AI_ASSISTANT=true

# Database Configuration (usando PostgreSQL Docker)
POSTGRES_URL=postgresql://gabriel:chatbot123@localhost:5433/chatbot_db

# Redis Cache (usando Redis Docker)
REDIS_URL=redis://localhost:6380

# AI Model Configuration (used when starting Docker container)
# These are passed to the Docker container when it starts
INFERENCE_MODEL=gemma3:12b

# Server Configuration
HOST=0.0.0.0
PORT=8003

# AI Assistant REST API endpoints
AI_ASSISTANT_START_API_URL=http://localhost:8002/ai_assistant/start_docker
AI_ASSISTANT_KILL_API_URL=http://localhost:8002/ai_assistant/kill_docker

# AI Assistant Agent endpoint (the running container API)
AI_ASSISTANT_API_URL=http://localhost:8001

# Docker startup payload for AI Assistant
AI_ASSISTANT_DB_IP_ADDRESS=host.docker.internal
AI_ASSISTANT_CONTAINER_NAME=ai_assistant_global
AI_ASSISTANT_INTERNAL_PORT=8001
AI_ASSISTANT_HEALTH_TIMEOUT_SECONDS=180
AI_ASSISTANT_POLL_INTERVAL_SECONDS=2.0
SESSION_IDLE_TTL_SECONDS=600
SESSION_SWEEP_INTERVAL_SECONDS=60

# Docker Configuration
DOCKER_IMAGE_NAME=ai_assistant_image
