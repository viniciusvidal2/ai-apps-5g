# AI Assistant Configuration
# Set to "true" to enable AI Assistant, "false" for mock mode
USE_AI_ASSISTANT=false

# Database Configuration (usando PostgreSQL Docker)
POSTGRES_URL=postgresql://gabriel:chatbot123@localhost:5433/chatbot_db

# Redis Cache (usando Redis Docker)
REDIS_URL=redis://localhost:6380

# AI Model Configuration (only used when USE_AI_ASSISTANT=true)
EMBEDDING_MODEL=qwen3-embedding:latest
INFERENCE_MODEL=gpt-oss:120b

# ChromaDB Configuration
PERSIST_PATH=./chroma_db
COLLECTION_NAME=dev_collection

# Server Configuration
HOST=0.0.0.0
PORT=8000
